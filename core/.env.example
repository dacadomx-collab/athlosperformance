[APLICACION]
APP_ENV = "production"
APP_URL = "https://athlosperformance.tourfindy.com"

[BASE_DE_DATOS]
DB_HOST = "localhost"
DB_PORT = "3306"
DB_NAME = "tourfindycom_athlosp_db"
DB_USER = "tourfindycom_athlosp_db_user"
DB_PASS = "INGRESE_AQUÍ_SU_CONTRASENA_DE_BASE_DE_DATOS"
DB_CHARSET = "utf8mb4"

[SEGURIDAD_CORS]
; Dominios validados en lista blanca para el intercambio estricto de APIs JSON
ALLOWED_ORIGINS = "http://localhost,http://localhost:3000,https://athlosperformance.tourfindy.com"

[MENSAJERIA_SMTP]
SMTP_HOST = "athlosperformance.tourfindy.com"
SMTP_PORT = "465"
SMTP_USER = "hola@athlosperformance.tourfindy.com"
SMTP_PASS = "INGRESE_AQUÍ_SU_CONTRASENA_SMTP_CORPORATIVA"
SMTP_AUTH = "true"
SMTP_SECURE = "ssl"