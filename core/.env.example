; ===================================================================
; ATHLOS PERFORMANCE BCS COGNITIVE ENGINE V1.0
; PLANTILLA DE CONFIGURACIÓN MAESTRA DE ENTORTNO (SINTAXIS INI)
; ===================================================================

[APLICACION]
APP_ENV = "production"
APP_URL = "https://athlosperformance.tourfindy.com"

[BASE_DE_DATOS]
DB_HOST = "localhost"
DB_PORT = "3306"
DB_NAME = "tourfindycom_athlosp_db"
DB_USER = "tourfindycom_athlosp_db_user"
DB_PASS = "INGRESE_AQUÍ_SU_CONTRASENA_DE_BASE_DE_DATOS"
DB_CHARSET = "utf8mb4"

[SEGURIDAD_CORS]
; Dominios validados en lista blanca para el intercambio estricto de APIs JSON
ALLOWED_ORIGINS = "http://localhost,http://localhost:3000,https://athlosperformance.tourfindy.com"

[MENSAJERIA_SMTP]
SMTP_HOST = "athlosperformance.tourfindy.com"
SMTP_PORT = "465"
SMTP_USER = "hola@athlosperformance.tourfindy.com"
SMTP_PASS = "INGRESE_AQUÍ_SU_CONTRASENA_SMTP_CORPORATIVA"
SMTP_AUTH = "true"
SMTP_SECURE = "ssl"

[API_INTERNA]
; Secreto para llamadas servidor-a-servidor (bots de WhatsApp, motor
; conversacional) en la cabecera "X-Athlos-Api-Key" al llamar a /ssos/api/*.
; Generar uno real con: php -r "echo bin2hex(random_bytes(32));"
API_WEBHOOK_SECRET = "INGRESE_AQUI_UN_SECRETO_ALEATORIO_LARGO"

; Secreto distinto, exclusivo para firmar (HMAC-SHA256) los tokens del
; reporte público del Athlos Score (72h de vigencia).
; Generar uno real con: php -r "echo bin2hex(random_bytes(32));"
HMAC_SECRET = "INGRESE_AQUI_OTRO_SECRETO_ALEATORIO_LARGO_DISTINTO"