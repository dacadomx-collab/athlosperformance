; ===================================================================
; ATHLOS SSOS v1.0 — BACKOFFICE (PHP/Bootstrap standalone)
; PLANTILLA DE CONFIGURACIÓN DE ENTORNO (SINTAXIS INI)
; Copiar a ".env" en esta misma carpeta y rellenar con valores reales.
; ".env" real NUNCA se sube al repositorio (ver .gitignore raíz).
; ===================================================================

[APLICACION]
APP_ENV = "local"
APP_URL = "http://localhost/Athlos_Performance/public/ssos"

[BASE_DE_DATOS]
DB_HOST = "localhost"
DB_PORT = "3306"
DB_NAME = "athlos_engine_db"
DB_USER = "root"
DB_PASS = ""
DB_CHARSET = "utf8mb4"

[SEGURIDAD_CORS]
; Dominios validados en lista blanca para el webhook /api/leads_webhook.php
ALLOWED_ORIGINS = "http://localhost:3000,https://athlosperformance.tourfindy.com"

[API_INTERNA]
; Secreto para llamadas servidor-a-servidor (bots de WhatsApp, motor
; conversacional) en la cabecera "X-Athlos-Api-Key" al llamar a /ssos/api/*.
; El frontend Next.js NUNCA envía este valor (ver RESUMEN_EJECUCION_SISTEMA.md §7.1).
; Generar uno real con: php -r "echo bin2hex(random_bytes(32));"
API_WEBHOOK_SECRET = "INGRESE_AQUI_UN_SECRETO_ALEATORIO_LARGO"

; Secreto distinto, exclusivo para firmar (HMAC-SHA256) los tokens del
; reporte público del Athlos Score™ (72h de vigencia). Separado de
; API_WEBHOOK_SECRET a propósito: son superficies de riesgo distintas.
; Generar uno real con: php -r "echo bin2hex(random_bytes(32));"
HMAC_SECRET = "INGRESE_AQUI_OTRO_SECRETO_ALEATORIO_LARGO_DISTINTO"
